{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["./globalexpress.d.ts"]
  },
  "include": [
    "src"
, "globalexpress.d.ts"  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}